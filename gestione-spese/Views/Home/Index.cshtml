@model IEnumerable<gestione_spese.Models.Gruppo>

@{
    ViewData["Title"] = "Home Page - Gestione Spese";
}

<!-- Forza il caricamento di Bootstrap via CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
<!-- Icone -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="text-center mb-5 mt-4">
    <h1 class="display-4 fw-bold text-primary">Gestore Spese Condivise</h1>
    <p class="lead">Gestisci facilmente i bilanci tra amici, coinquilini o compagni di viaggio.</p>
</div>

<div class="container">
    @if (ViewBag.Errore != null)
    {
        <div class="alert alert-danger" role="alert">
            @ViewBag.Errore
        </div>
    }

    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h3>I tuoi Gruppi attivi</h3>
        </div>
        <div class="col-md-4 text-end">
            <button class="btn btn-success rounded-pill px-4 shadow-sm" onclick="alert('Presto creeremo la pagina per aggiungere i gruppi da qui!')">
                <i class="bi bi-plus-circle"></i> + Nuovo Gruppo
            </button>
        </div>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var gruppo in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <h5 class="card-title text-dark fw-bold">@gruppo.Nome</h5>
                            
                            @if (!string.IsNullOrEmpty(gruppo.Descrizione))
                            {
                                <p class="card-text text-muted mb-2">@gruppo.Descrizione</p>
                            }
                            
                            <p class="card-text text-muted small">Creato il: @gruppo.DataCreazione.ToString("dd/MM/yyyy")</p>
                            
                            <p class="card-text">
                                <span class="badge bg-info text-dark">
                                    <i class="bi bi-people-fill"></i> Utenti iscritti: @(gruppo.Utenti?.Count ?? 0)
                                </span>
                            </p>
                        </div>
                        <div class="card-footer bg-white border-top-0 pb-3 text-center">
                            <button class="btn btn-outline-primary w-100" onclick="alert('Apriremo la lista spese di questo gruppo!')">Vedi Dettagli</button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center p-5 bg-light rounded-3 shadow-sm">
                <h4 class="text-muted">Nessun gruppo trovato</h4>
                <p>Usa le API Swagger per creare il tuo primo gruppo.</p>
                <small class="text-danger fw-bold">Ricorda: Se hai riavviato l'applicazione, il database In-Memory si è svuotato! Devi reinserirlo da Swagger.</small>
            </div>
        }
    </div>
</div>
